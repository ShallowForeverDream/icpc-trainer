{
  "manifest_version": 3,
  "name": "icpc-trainer Browser Bridge",
  "version": "0.8.0",
  "description": "Import statements and securely submit to Codeforces or Universal Cup from icpc-trainer.",
  "permissions": ["storage", "tabs"],
  "background": { "service_worker": "background.js" },
  "host_permissions": [
    "https://icpc-trainer-shallowdream.safe-chime-4451.chatgpt.site/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://codeforces.com/*",
    "https://contest.ucup.ac/*",
    "https://qoj.ac/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://icpc-trainer-shallowdream.safe-chime-4451.chatgpt.site/*", "http://localhost/*", "http://127.0.0.1/*"],
      "js": ["trainer-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://codeforces.com/*"],
      "js": ["codeforces-fill.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://contest.ucup.ac/*", "https://qoj.ac/*"],
      "js": ["qoj-fill.js"],
      "run_at": "document_idle"
    }
  ]
}
